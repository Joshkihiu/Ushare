# Copy this file to .env and fill in your real values. Never commit .env.

# 'sandbox' while testing, 'production' when you have live Daraja access
DARAJA_ENV=sandbox

# From your Daraja app (https://developer.safaricom.co.ke)
CONSUMER_KEY=
CONSUMER_SECRET=

# Your Paybill/Till shortcode
BUSINESS_SHORTCODE=

# Lipa Na M-Pesa Online passkey (from the Daraja portal, tied to your shortcode)
PASSKEY=

# MUST be a public HTTPS URL Daraja can reach — localhost will NOT work.
# For local dev: run `ngrok http 4000` and paste the https URL + /api/mpesa/callback
CALLBACK_URL=https://your-public-url.ngrok-free.app/api/mpesa/callback

PORT=4000
